{
  "compilerOptions": {
    "target": "ESNext", "module": "ESNext", "moduleResolution": "bundler",
    "lib": ["ES2020"], "jsx": "react-jsx", "strict": true, "esModuleInterop": true,
    "skipLibCheck": true, "noEmit": true, "resolveJsonModule": true, "isolatedModules": true
  },
  "include": ["src/**/*"], "exclude": ["node_modules"]
}
